# Local dev and tests need none of this — no DATABASE_URL means src/db/client.ts
# falls back to an embedded PGlite database, auto-migrated and auto-seeded.

# Production only. Vercel's Neon integration injects these automatically into
# the deployed environment; nothing to set by hand there. Only fill this file
# in if you're pointing a local run at a real Neon database on purpose.
# Pooled (PgBouncer) connection — used at request time (src/db/client.ts).
# If set manually, use sslmode=verify-full in the URL; the app normalizes legacy
# sslmode=require/prefer/verify-ca values to that explicit mode at runtime and
# during migrations.
DATABASE_URL=

# Direct/unpooled connection — used for schema migrations (`pnpm db:migrate`),
# since DDL over a transaction-mode pooler is unreliable. Neon calls this the
# "unpooled" connection string; falls back to DATABASE_URL if unset.
DATABASE_URL_UNPOOLED=

# Required in production (NextAuth fails loudly without it there); dev/test
# fall back to a hardcoded non-production secret. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Transactional email through Resend. Use a verified Resend sender; the friendly
# sender name is supported (for example, "Blue Mantis <bookings@example.com>").
# Keep both values server-only — neither may use a NEXT_PUBLIC_ prefix.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Canonical public origin used only to build private waiver-completion links.
# Set the deployed custom domain, including https:// and without a trailing slash.
APP_HOST=
